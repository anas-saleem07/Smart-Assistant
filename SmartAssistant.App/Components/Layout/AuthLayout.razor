@inherits LayoutComponentBase

<div class="sa-auth-layout">
    <main class="sa-auth-main">
        @Body
    </main>
</div>

<style>
    .sa-auth-layout {
        min-height: 100vh;
        background: radial-gradient(900px 500px at top right, rgba(124, 92, 255, 0.10), transparent 45%), linear-gradient(180deg, #070a12 0%, #0b1020 100%);
        display: flex;
        align-items: stretch;
        justify-content: center;
    }

    .sa-auth-main {
        width: 100%;
        min-height: 100vh;
        padding: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
    }

    @@media (max-width: 768px) {
        .sa-auth-main {
            padding: 16px;
            align-items: stretch;
        }
    }
</style>