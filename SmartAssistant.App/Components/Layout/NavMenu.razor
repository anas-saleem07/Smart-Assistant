@using Microsoft.AspNetCore.Components.Routing

@* =========================
   Nav Toggle
   ========================= *@
<button class="sa-nav-toggle" @onclick="ToggleNav" aria-label="Toggle navigation">
    <span class="sa-nav-toggle-bars"></span>
</button>

<div class="sa-nav-backdrop @(isOpen ? "open" : "")" @onclick="CloseNav"></div>

@* =========================
   Sidebar Nav
   ========================= *@
<aside class="sa-nav @(isOpen ? "open" : "")">
    @* =========================
       Brand Header
       ========================= *@
    <div class="sa-nav-header">
        <div class="sa-nav-brand">
            <div class="sa-nav-logo-wrap">
                <div class="sa-nav-logo-mark"></div>
                <div class="sa-nav-logo-text">SA</div>
            </div>

            <div class="sa-nav-brand-text">
                <div class="sa-nav-title">SmartAssistant</div>
                <div class="sa-nav-subtitle">Personal productivity</div>
            </div>
        </div>
    </div>

    @* =========================
       Main Links
       ========================= *@
    <nav class="sa-nav-links">
        <div class="sa-nav-section">Main</div>

        @* <NavLink class="sa-nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-home"></span>
            <span>Home</span>
        </NavLink> *@

        <NavLink class="sa-nav-link" href="reminders" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-reminders"></span>
            <span>Reminders</span>
        </NavLink>

        <NavLink class="sa-nav-link" href="reminder-history" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-reminder-history"></span>
            <span>Reminder History</span>
        </NavLink>

        <NavLink class="sa-nav-link" href="processed-email-history" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-processed-email"></span>
            <span>Processed Emails</span>
        </NavLink>

        <div class="sa-nav-section">Utilities</div>

        @* <NavLink class="sa-nav-link" href="counter" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-counter"></span>
            <span>Counter</span>
        </NavLink>

        <NavLink class="sa-nav-link" href="weather" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-weather"></span>
            <span>Weather</span>
        </NavLink> *@
    </nav>

    @* =========================
       Footer
       ========================= *@
    <div class="sa-nav-footer">
        <NavLink class="sa-nav-link sa-nav-link-gmail" href="google-auth" @onclick="CloseNav">
            <span class="sa-gmail-badge">G</span>
            <span>Gmail Access</span>
        </NavLink>
    </div>
</aside>

@code {
    #region Fields
    private bool isOpen = false;
    #endregion

    #region Nav Actions
    private void ToggleNav() => isOpen = !isOpen;

    private void CloseNav()
    {
        isOpen = false;
    }
    #endregion
}

<style>
    /* =========================
           Nav Toggle
           ========================= */
    .sa-nav-toggle {
        display: none;
        position: fixed;
        top: 14px;
        left: 14px;
        z-index: 2000;
        width: 46px;
        height: 46px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: rgba(8, 12, 22, 0.92);
        backdrop-filter: blur(10px);
        cursor: pointer;
    }

    .sa-nav-toggle-bars,
    .sa-nav-toggle-bars::before,
    .sa-nav-toggle-bars::after {
        content: "";
        display: block;
        width: 18px;
        height: 2px;
        background: rgba(235, 240, 255, 0.95);
        border-radius: 999px;
        margin: 0 auto;
        position: relative;
    }

        .sa-nav-toggle-bars::before {
            position: absolute;
            top: -6px;
            left: 0;
        }

        .sa-nav-toggle-bars::after {
            position: absolute;
            top: 6px;
            left: 0;
        }

    .sa-nav-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1400;
        background: rgba(0, 0, 0, 0.45);
    }

        .sa-nav-backdrop.open {
            display: block;
        }

    /* =========================
           Sidebar Shell
           ========================= */
    .sa-nav {
        width: 280px;
        min-height: 100vh;
        padding: 18px 14px;
        background: radial-gradient(600px 380px at 0% 0%, rgba(124, 92, 255, 0.18), transparent 50%), linear-gradient(180deg, #0b1020 0%, #070a12 100%);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .sa-nav-header {
        padding: 8px 8px 2px;
    }

    .sa-nav-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sa-nav-logo-wrap {
        position: relative;
        width: 44px;
        height: 44px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.22), rgba(0, 200, 255, 0.18));
        border: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .sa-nav-logo-mark {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.18), transparent 35%), radial-gradient(circle at 70% 70%, rgba(124, 92, 255, 0.28), transparent 40%);
    }

    .sa-nav-logo-text {
        position: relative;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.8px;
        color: #f3f6ff;
    }

    .sa-nav-brand-text {
        min-width: 0;
    }

    .sa-nav-title {
        font-size: 16px;
        font-weight: 800;
        color: rgba(235, 240, 255, 0.96);
        line-height: 1.1;
    }

    .sa-nav-subtitle {
        margin-top: 3px;
        font-size: 12px;
        color: rgba(235, 240, 255, 0.58);
    }

    /* =========================
           Nav Links
           ========================= */
    .sa-nav-links {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-top: 4px;
    }

    .sa-nav-section {
        margin: 12px 10px 4px;
        font-size: 11px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: rgba(235, 240, 255, 0.48);
    }

    .sa-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 12px;
        border-radius: 14px;
        color: rgba(235, 240, 255, 0.84);
        text-decoration: none;
        border: 1px solid transparent;
        transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
    }

        .sa-nav-link:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 255, 255, 0.08);
            transform: translateY(-1px);
        }

        .sa-nav-link.active {
            background: linear-gradient(135deg, rgba(124, 92, 255, 0.24), rgba(0, 200, 255, 0.12));
            border-color: rgba(124, 92, 255, 0.22);
            color: #f2f5ff;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.18);
        }

    /* =========================
           Base Icon
           ========================= */
    .sa-link-icon {
        width: 18px;
        height: 18px;
        position: relative;
        flex-shrink: 0;
        opacity: 0.95;
        display: inline-block;
        transition: transform 0.2s ease;
    }

    .sa-nav-link:hover .sa-link-icon {
        transform: scale(1.08);
    }

    /* =========================
           Legacy Simple Icons
           ========================= */
    .sa-link-icon-home {
        border: 2px solid currentColor;
        border-radius: 4px;
    }

        .sa-link-icon-home::before {
            content: "";
            position: absolute;
            left: 2px;
            top: -4px;
            width: 10px;
            height: 10px;
            border-top: 2px solid currentColor;
            border-left: 2px solid currentColor;
            transform: rotate(45deg);
        }

    .sa-link-icon-counter {
        border: 2px solid currentColor;
        border-radius: 4px;
    }

        .sa-link-icon-counter::before {
            content: "";
            position: absolute;
            left: 3px;
            top: 8px;
            width: 10px;
            height: 2px;
            background: currentColor;
            border-radius: 999px;
        }

        .sa-link-icon-counter::after {
            content: "";
            position: absolute;
            left: 7px;
            top: 4px;
            width: 2px;
            height: 10px;
            background: currentColor;
            border-radius: 999px;
        }

    .sa-link-icon-weather {
        border: 2px solid currentColor;
        border-radius: 999px;
    }

        .sa-link-icon-weather::before {
            content: "";
            position: absolute;
            right: -2px;
            top: -2px;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

    /* =========================
           Reminders Icon
           Calendar style
           ========================= */
    .sa-link-icon-reminders {
        border: 2px solid #8f72ff;
        border-radius: 4px;
        box-shadow: 0 0 10px rgba(124, 92, 255, 0.35);
    }

        .sa-link-icon-reminders::before {
            content: "";
            position: absolute;
            left: 2px;
            right: 2px;
            top: 4px;
            height: 2px;
            background: #8f72ff;
            border-radius: 999px;
        }

        .sa-link-icon-reminders::after {
            content: "";
            position: absolute;
            top: -3px;
            left: 3px;
            width: 2px;
            height: 5px;
            background: #8f72ff;
            border-radius: 999px;
            box-shadow: 8px 0 0 #8f72ff;
        }

    /* =========================
           Reminder History Icon
           Clock style
           ========================= */
    .sa-link-icon-reminder-history {
        border: 2px solid rgba(232, 236, 255, 0.75);
        border-radius: 50%;
    }

        .sa-link-icon-reminder-history::before {
            content: "";
            position: absolute;
            left: 8px;
            top: 3px;
            width: 2px;
            height: 6px;
            background: rgba(232, 236, 255, 0.75);
            border-radius: 999px;
        }

        .sa-link-icon-reminder-history::after {
            content: "";
            position: absolute;
            left: 8px;
            top: 8px;
            width: 5px;
            height: 2px;
            background: rgba(232, 236, 255, 0.75);
            border-radius: 999px;
            transform-origin: left center;
            transform: rotate(35deg);
        }

    /* =========================
           Processed Email Icon
           Envelope style
           ========================= */
    .sa-link-icon-processed-email {
        border: 2px solid #35cfff;
        border-radius: 4px;
        box-shadow: 0 0 10px rgba(0, 200, 255, 0.28);
    }

        .sa-link-icon-processed-email::before {
            content: "";
            position: absolute;
            left: 1px;
            right: 1px;
            top: 2px;
            height: 2px;
            background: linear-gradient(90deg, transparent 0%, transparent 8%, #35cfff 8%, #35cfff 42%, transparent 42%, transparent 58%, #7c5cff 58%, #7c5cff 92%, transparent 92%, transparent 100%);
            transform: skewY(24deg);
        }

        .sa-link-icon-processed-email::after {
            content: "";
            position: absolute;
            left: 2px;
            right: 2px;
            top: 3px;
            height: 8px;
            border-left: 2px solid #35cfff;
            border-right: 2px solid #7c5cff;
            transform: skewY(-28deg);
            opacity: 0.95;
        }

    /* =========================
           Active Icon States
           ========================= */
    .sa-nav-link.active .sa-link-icon-reminders {
        border-color: #a68cff;
        box-shadow: 0 0 14px rgba(124, 92, 255, 0.45);
    }

    .sa-nav-link.active .sa-link-icon-reminder-history {
        border-color: rgba(255, 255, 255, 0.92);
    }

    .sa-nav-link.active .sa-link-icon-processed-email {
        border-color: #55d8ff;
        box-shadow: 0 0 14px rgba(0, 200, 255, 0.40);
    }

    /* =========================
           Footer
           ========================= */
    .sa-nav-footer {
        margin-top: auto;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .sa-nav-link-gmail {
        background: rgba(255, 255, 255, 0.04);
    }

    .sa-gmail-badge {
        width: 22px;
        height: 22px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
        color: #f8fbff;
        background: linear-gradient(135deg, rgba(220, 70, 70, 0.95), rgba(255, 140, 60, 0.90));
        flex-shrink: 0;
    }

    /* =========================
           Mobile
           ========================= */
    @@media (max-width: 900px) {
        .sa-nav-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .sa-nav {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1500;
            transform: translateX(-110%);
            transition: transform 180ms ease;
            box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
        }

            .sa-nav.open {
                transform: translateX(0%);
            }
    }
</style>