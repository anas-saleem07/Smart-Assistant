@using Microsoft.AspNetCore.Components.Routing

<button class="sa-nav-toggle" @onclick="ToggleNav" aria-label="Toggle navigation">
    <span class="sa-nav-toggle-bars"></span>
</button>

<div class="sa-nav-backdrop @(isOpen ? "open" : "")" @onclick="CloseNav"></div>

<aside class="sa-nav @(isOpen ? "open" : "")">
    <div class="sa-nav-header">
        <div class="sa-nav-brand">
            <div class="sa-nav-logo-wrap">
                <div class="sa-nav-logo-mark"></div>
                <div class="sa-nav-logo-text">SA</div>
            </div>

            <div class="sa-nav-brand-text">
                <div class="sa-nav-title">SmartAssistant</div>
                <div class="sa-nav-subtitle">Personal productivity</div>
            </div>
        </div>
    </div>

    <nav class="sa-nav-links">
        <div class="sa-nav-section">Main</div>

        <NavLink class="sa-nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-home"></span>
            <span>Home</span>
        </NavLink>

        <NavLink class="sa-nav-link" href="reminders" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-reminders"></span>
            <span>Reminders</span>
        </NavLink>

        <div class="sa-nav-section">Utilities</div>

        <NavLink class="sa-nav-link" href="counter" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-counter"></span>
            <span>Counter</span>
        </NavLink>

        <NavLink class="sa-nav-link" href="weather" @onclick="CloseNav">
            <span class="sa-link-icon sa-link-icon-weather"></span>
            <span>Weather</span>
        </NavLink>
    </nav>

    <div class="sa-nav-footer">
        <NavLink class="sa-nav-link sa-nav-link-gmail" href="google-auth" @onclick="CloseNav">
            <span class="sa-gmail-badge">G</span>
            <span>Gmail Access</span>
        </NavLink>
    </div>
</aside>

@code {
    private bool isOpen = false;

    private void ToggleNav() => isOpen = !isOpen;

    private void CloseNav()
    {
        isOpen = false;
    }
}

<style>
    .sa-nav-toggle {
        display: none;
        position: fixed;
        top: 14px;
        left: 14px;
        z-index: 2000;
        width: 46px;
        height: 46px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: rgba(8, 12, 22, 0.92);
        backdrop-filter: blur(10px);
        cursor: pointer;
    }

    .sa-nav-toggle-bars,
    .sa-nav-toggle-bars::before,
    .sa-nav-toggle-bars::after {
        content: "";
        display: block;
        width: 18px;
        height: 2px;
        background: rgba(235, 240, 255, 0.95);
        border-radius: 999px;
        margin: 0 auto;
        position: relative;
    }

        .sa-nav-toggle-bars::before {
            position: absolute;
            top: -6px;
            left: 0;
        }

        .sa-nav-toggle-bars::after {
            position: absolute;
            top: 6px;
            left: 0;
        }

    .sa-nav-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1400;
        background: rgba(0, 0, 0, 0.45);
    }

        .sa-nav-backdrop.open {
            display: block;
        }

    .sa-nav {
        width: 280px;
        min-height: 100vh;
        padding: 18px 14px;
        background: radial-gradient(600px 380px at 0% 0%, rgba(124, 92, 255, 0.18), transparent 50%), linear-gradient(180deg, #0b1020 0%, #070a12 100%);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .sa-nav-header {
        padding: 8px 8px 2px;
    }

    .sa-nav-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sa-nav-logo-wrap {
        position: relative;
        width: 44px;
        height: 44px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.22), rgba(0, 200, 255, 0.18));
        border: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .sa-nav-logo-mark {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.18), transparent 35%), radial-gradient(circle at 70% 70%, rgba(124, 92, 255, 0.28), transparent 40%);
    }

    .sa-nav-logo-text {
        position: relative;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.8px;
        color: #f3f6ff;
    }

    .sa-nav-brand-text {
        min-width: 0;
    }

    .sa-nav-title {
        font-size: 16px;
        font-weight: 800;
        color: rgba(235, 240, 255, 0.96);
        line-height: 1.1;
    }

    .sa-nav-subtitle {
        margin-top: 3px;
        font-size: 12px;
        color: rgba(235, 240, 255, 0.58);
    }

    .sa-nav-links {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-top: 4px;
    }

    .sa-nav-section {
        margin: 12px 10px 4px;
        font-size: 11px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: rgba(235, 240, 255, 0.48);
    }

    .sa-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 12px;
        border-radius: 14px;
        color: rgba(235, 240, 255, 0.84);
        text-decoration: none;
        border: 1px solid transparent;
        transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
    }

        .sa-nav-link:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 255, 255, 0.08);
            transform: translateY(-1px);
        }

        .sa-nav-link.active {
            background: linear-gradient(135deg, rgba(124, 92, 255, 0.24), rgba(0, 200, 255, 0.12));
            border-color: rgba(124, 92, 255, 0.22);
            color: #f2f5ff;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.18);
        }

    .sa-link-icon {
        width: 18px;
        height: 18px;
        position: relative;
        flex-shrink: 0;
        opacity: 0.95;
    }

    .sa-link-icon-home::before,
    .sa-link-icon-reminders::before,
    .sa-link-icon-counter::before,
    .sa-link-icon-weather::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 5px;
        border: 2px solid currentColor;
    }

    .sa-link-icon-home::after {
        content: "";
        position: absolute;
        left: 3px;
        top: -2px;
        width: 10px;
        height: 10px;
        border-top: 2px solid currentColor;
        border-left: 2px solid currentColor;
        transform: rotate(45deg);
        background: transparent;
    }

    .sa-link-icon-reminders::after {
        content: "";
        position: absolute;
        left: 7px;
        top: 2px;
        width: 2px;
        height: 6px;
        background: currentColor;
        border-radius: 999px;
        box-shadow: 3px 4px 0 0 currentColor;
    }

    .sa-link-icon-counter::after {
        content: "";
        position: absolute;
        left: 3px;
        top: 7px;
        width: 10px;
        height: 2px;
        background: currentColor;
        border-radius: 999px;
        box-shadow: 4px -4px 0 0 currentColor;
    }

    .sa-link-icon-weather::after {
        content: "";
        position: absolute;
        right: -1px;
        top: -1px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    .sa-nav-footer {
        margin-top: auto;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .sa-nav-link-gmail {
        background: rgba(255, 255, 255, 0.04);
    }

    .sa-gmail-badge {
        width: 22px;
        height: 22px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
        color: #f8fbff;
        background: linear-gradient(135deg, rgba(220, 70, 70, 0.95), rgba(255, 140, 60, 0.90));
        flex-shrink: 0;
    }

    @@media (max-width: 900px) {
        .sa-nav-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .sa-nav {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1500;
            transform: translateX(-110%);
            transition: transform 180ms ease;
            box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
        }

            .sa-nav.open {
                transform: translateX(0%);
            }
    }
</style>