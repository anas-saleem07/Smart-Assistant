@page "/google-auth"
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Net.Http.Json
@using Microsoft.Maui.ApplicationModel

<div class="ga-page">
    <div class="ga-shell">

        <section class="ga-card ga-hero">
            <div class="ga-chip">Core access required</div>

            <h1 class="ga-title">Connect Gmail to continue</h1>

            <p class="ga-subtitle">
                Gmail connection is required because your reminder automation,
                email processing, auto-reply flow, and calendar checks all depend on Google.
            </p>

            @if (!string.IsNullOrWhiteSpace(statusText))
            {
                <div class="ga-status @(isError ? "ga-status-error" : "ga-status-ok")">
                    <span class="ga-status-icon">@(isError ? "!" : "OK")</span>
                    <span class="ga-status-text">@statusText</span>
                    <button class="ga-status-close" @onclick="ClearStatus">x</button>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(debugText))
            {
                <div class="ga-debug">
                    <pre>@debugText</pre>
                </div>
            }

            @if (isLoading)
            {
                <div class="ga-loading">
                    <span class="ga-spinner"></span>
                    <span>Checking Gmail connection...</span>
                </div>
            }
            else
            {
                <div class="ga-grid">
                    <div class="ga-panel">
                        <div class="ga-label">Status</div>
                        <div class="ga-value">
                            @(authStatus?.IsConnected == true ? "Connected" : "Not Connected")
                        </div>
                        <div class="ga-help">@authStatus?.Message</div>
                    </div>

                    <div class="ga-panel">
                        <div class="ga-label">Email</div>
                        <div class="ga-value">
                            @(string.IsNullOrWhiteSpace(authStatus?.Email) ? "-" : authStatus?.Email)
                        </div>
                        <div class="ga-help">This Gmail account will be used by the system.</div>
                    </div>
                </div>

                <div class="ga-actions">
                    @if (authStatus?.IsConnected == true)
                    {
                        <button class="ga-btn ga-btn-primary" @onclick="GoToReminders">
                            Continue to Reminders
                        </button>

                        <button class="ga-btn ga-btn-danger" @onclick="DisconnectAsync" disabled="@isBusy">
                            @if (isBusy)
                            {
                                <span class="ga-spinner"></span>
                                <span>Disconnecting...</span>
                            }
                            else
                            {
                                <span>Logout Gmail</span>
                            }
                        </button>
                    }
                    else
                    {
                        <button class="ga-btn ga-btn-primary" @onclick="ConnectGoogleAsync" disabled="@isBusy">
                            @if (isBusy)
                            {
                                <span class="ga-spinner"></span>
                                <span>Opening...</span>
                            }
                            else
                            {
                                <span>Login with Gmail</span>
                            }
                        </button>

                        <button class="ga-btn" @onclick="LoadStatusAsync" disabled="@isBusy">
                            Refresh Status
                        </button>

                        <button class="ga-btn" @onclick="TestConnectEndpointAsync" disabled="@isBusy">
                            Test Connect Endpoint
                        </button>
                    }
                </div>
            }
        </section>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isBusy;
    private bool isError;
    private string statusText = "";
    private string debugText = "";
    private GoogleConnectionStatusModel? authStatus;

    protected override async Task OnInitializedAsync()
    {
        ReadQueryState();
        await LoadStatusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var pendingDeepLink = App.ConsumePendingDeepLink();

        if (string.IsNullOrWhiteSpace(pendingDeepLink))
            return;

        if (pendingDeepLink.Contains("status=success", StringComparison.OrdinalIgnoreCase))
        {
            SetStatus("Gmail connected successfully.", false);
            await LoadStatusAsync();
            return;
        }

        if (pendingDeepLink.Contains("status=error", StringComparison.OrdinalIgnoreCase))
        {
            var message = ExtractQueryValue(pendingDeepLink, "message");

            SetStatus(
                string.IsNullOrWhiteSpace(message)
                    ? "Google sign-in failed or was cancelled."
                    : $"Google sign-in failed: {message}",
                true);

            await InvokeAsync(StateHasChanged);
        }
    }

    private void ReadQueryState()
    {
        var absoluteUri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryValues = ParseQueryString(absoluteUri.Query);

        if (queryValues.TryGetValue("connected", out var connectedValue) &&
            connectedValue == "1")
        {
            SetStatus("Gmail connected successfully.", false);
        }

        if (queryValues.TryGetValue("error", out var errorValue) &&
            !string.IsNullOrWhiteSpace(errorValue))
        {
            SetStatus(errorValue, true);
        }
    }

    private void ClearStatus()
    {
        statusText = "";
        isError = false;
    }

    private void SetStatus(string message, bool error)
    {
        statusText = message;
        isError = error;
    }

    private void SetDebug(string message)
    {
        debugText = message;
    }

    private string BuildAbsoluteUrl(string relativePath)
    {
        return new Uri(Http.BaseAddress!, relativePath).ToString();
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            isLoading = true;
            ClearStatus();

            var requestUrl = BuildAbsoluteUrl("api/google-oauth/status");

            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Request: GET {requestUrl}");

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.GetAsync("api/google-oauth/status", cts.Token);
            var body = await response.Content.ReadAsStringAsync(cts.Token);

            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Request: GET {requestUrl}\n" +
                $"Status: {(int)response.StatusCode} {response.StatusCode}\n" +
                $"Body: {body}");

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Failed to check Gmail status. Status={(int)response.StatusCode}.", true);
                authStatus = null;
                return;
            }

            authStatus = System.Text.Json.JsonSerializer.Deserialize<GoogleConnectionStatusModel>(
                body,
                new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
        }
        catch (TaskCanceledException ex)
        {
            SetStatus("Request timed out while checking Gmail status.", true);
            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Exception: {ex.GetType().FullName}\n" +
                $"Message: {ex.Message}");
            authStatus = null;
        }
        catch (Exception ex)
        {
            SetStatus("Failed to check Gmail status: " + ex.Message, true);
            SetDebug(BuildExceptionDebugText("api/google-oauth/status", ex));
            authStatus = null;
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConnectGoogleAsync()
    {
        if (isBusy)
            return;

        try
        {
            isBusy = true;
            ClearStatus();

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var platform = DeviceInfo.Platform == DevicePlatform.Android
                ? "android"
                : "windows";

            var result = await Http.GetFromJsonAsync<GoogleConnectResponse>(
                $"api/google-oauth/connect?platform={platform}",
                cts.Token);

            if (result == null || string.IsNullOrWhiteSpace(result.Url))
            {
                SetStatus("Google auth URL was not returned.", true);
                return;
            }

            await Launcher.Default.OpenAsync(result.Url);
            SetStatus("Google login opened in browser. Complete login and return to the app.", false);
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while starting Gmail login.", true);
        }
        catch (Exception ex)
        {
            SetStatus("Failed to start Gmail login: " + ex.Message, true);
        }
        finally
        {
            isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task TestConnectEndpointAsync()
    {
        if (isBusy)
            return;

        try
        {
            isBusy = true;
            ClearStatus();

            var requestUrl = BuildAbsoluteUrl("api/google-oauth/connect");

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.GetAsync("api/google-oauth/connect", cts.Token);
            var body = await response.Content.ReadAsStringAsync(cts.Token);

            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Request: GET {requestUrl}\n" +
                $"Status: {(int)response.StatusCode} {response.StatusCode}\n" +
                $"Body: {body}");

            SetStatus($"Connect endpoint returned {(int)response.StatusCode}.", !response.IsSuccessStatusCode);
        }
        catch (Exception ex)
        {
            SetStatus($"Connect endpoint test failed: {ex.Message}", true);
            SetDebug(BuildExceptionDebugText("api/google-oauth/connect", ex));
        }
        finally
        {
            isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DisconnectAsync()
    {
        if (isBusy)
            return;

        try
        {
            isBusy = true;
            ClearStatus();

            var requestUrl = BuildAbsoluteUrl("api/google-oauth/disconnect");

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.PostAsync("api/google-oauth/disconnect", null, cts.Token);
            var body = await response.Content.ReadAsStringAsync(cts.Token);

            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Request: POST {requestUrl}\n" +
                $"Status: {(int)response.StatusCode} {response.StatusCode}\n" +
                $"Body: {body}");

            if (!response.IsSuccessStatusCode)
            {
                SetStatus("Disconnect failed: " + body, true);
                return;
            }

            SetStatus("Gmail disconnected successfully.", false);
            await LoadStatusAsync();
        }
        catch (TaskCanceledException ex)
        {
            SetStatus("Request timed out while disconnecting Gmail.", true);
            SetDebug(
                $"BaseAddress: {Http.BaseAddress}\n" +
                $"Exception: {ex.GetType().FullName}\n" +
                $"Message: {ex.Message}");
        }
        catch (Exception ex)
        {
            SetStatus("Failed to disconnect Gmail: " + ex.Message, true);
            SetDebug(BuildExceptionDebugText("api/google-oauth/disconnect", ex));
        }
        finally
        {
            isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string BuildExceptionDebugText(string relativePath, Exception ex)
    {
        var requestUrl = BuildAbsoluteUrl(relativePath);

        var inner = ex.InnerException != null
            ? $"\nInner Type: {ex.InnerException.GetType().FullName}\nInner Message: {ex.InnerException.Message}"
            : "";

        return
            $"BaseAddress: {Http.BaseAddress}\n" +
            $"Request: {requestUrl}\n" +
            $"Exception Type: {ex.GetType().FullName}\n" +
            $"Message: {ex.Message}" +
            inner;
    }

    private void GoToReminders()
    {
        Navigation.NavigateTo("/reminders");
    }

    private static Dictionary<string, string> ParseQueryString(string query)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(query))
            return result;

        var trimmedQuery = query.StartsWith("?")
            ? query.Substring(1)
            : query;

        var pairs = trimmedQuery.Split('&', StringSplitOptions.RemoveEmptyEntries);

        foreach (var pair in pairs)
        {
            var parts = pair.Split('=', 2);

            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1
                ? Uri.UnescapeDataString(parts[1])
                : "";

            if (!string.IsNullOrWhiteSpace(key))
                result[key] = value;
        }

        return result;
    }

    private static string ExtractQueryValue(string url, string key)
    {
        var questionMarkIndex = url.IndexOf('?');
        if (questionMarkIndex < 0)
            return "";

        var query = url.Substring(questionMarkIndex + 1);
        var parts = query.Split('&', StringSplitOptions.RemoveEmptyEntries);

        foreach (var part in parts)
        {
            var pair = part.Split('=', 2);

            if (pair.Length == 0)
                continue;

            var currentKey = Uri.UnescapeDataString(pair[0]);

            if (!currentKey.Equals(key, StringComparison.OrdinalIgnoreCase))
                continue;

            return pair.Length > 1
                ? Uri.UnescapeDataString(pair[1])
                : "";
        }

        return "";
    }

    public sealed class GoogleConnectionStatusModel
    {
        public bool IsConnected { get; set; }
        public bool NeedsReconnect { get; set; }
        public string Provider { get; set; } = "Gmail";
        public string Email { get; set; } = "";
        public string Message { get; set; } = "";
    }

    public sealed class GoogleConnectResponse
    {
        public string Url { get; set; } = "";
    }
}

<style>
    .ga-page {
        min-height: 100vh;
        background: radial-gradient(1200px 800px at 20% 10%, rgba(120, 90, 255, 0.18), transparent 55%), radial-gradient(1000px 700px at 80% 30%, rgba(0, 200, 255, 0.10), transparent 55%), linear-gradient(180deg, #0b0f1a 0%, #070a12 100%);
        color: #e8ecff;
        padding: 28px;
    }

    .ga-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .ga-card {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(10px);
    }

    .ga-hero {
        padding: 28px;
    }

    .ga-chip {
        display: inline-flex;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(124, 92, 255, 0.14);
        border: 1px solid rgba(124, 92, 255, 0.28);
        color: rgba(232, 236, 255, 0.92);
        font-size: 12px;
        margin-bottom: 16px;
    }

    .ga-title {
        font-size: 34px;
        margin: 0;
    }

    .ga-subtitle {
        margin: 8px 0 0;
        color: rgba(232, 236, 255, 0.72);
        line-height: 1.6;
        max-width: 760px;
    }

    .ga-status {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-top: 18px;
        border-radius: 14px;
    }

    .ga-status-ok {
        border: 1px solid rgba(0, 255, 163, 0.25);
        background: rgba(0, 255, 163, 0.08);
    }

    .ga-status-error {
        border: 1px solid rgba(255, 77, 77, 0.30);
        background: rgba(255, 77, 77, 0.10);
    }

    .ga-status-icon {
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: rgba(0,0,0,0.18);
        font-weight: 700;
    }

    .ga-status-text {
        flex: 1;
        color: rgba(232, 236, 255, 0.92);
    }

    .ga-status-close {
        border: none;
        background: transparent;
        color: rgba(232, 236, 255, 0.70);
        font-size: 18px;
        cursor: pointer;
    }

    .ga-debug {
        margin-top: 18px;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(0, 200, 255, 0.25);
        background: rgba(0, 200, 255, 0.08);
        color: rgba(232, 236, 255, 0.92);
        overflow-x: auto;
    }

        .ga-debug pre {
            margin: 0;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: Consolas, monospace;
            font-size: 12px;
        }

    .ga-loading {
        margin-top: 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .ga-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-top: 20px;
    }

    .ga-panel {
        padding: 18px;
        border-radius: 14px;
        background: rgba(0, 0, 0, 0.22);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .ga-label {
        font-size: 12px;
        color: rgba(232, 236, 255, 0.66);
        margin-bottom: 8px;
    }

    .ga-value {
        font-size: 22px;
        font-weight: 700;
        color: rgba(232, 236, 255, 0.96);
        margin-bottom: 8px;
    }

    .ga-help {
        color: rgba(232, 236, 255, 0.72);
        line-height: 1.5;
    }

    .ga-actions {
        display: flex;
        gap: 12px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

    .ga-btn {
        border-radius: 12px;
        padding: 12px 16px;
        border: 1px solid rgba(255,255,255,0.12);
        cursor: pointer;
        background: rgba(255,255,255,0.06);
        color: rgba(232, 236, 255, 0.90);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        white-space: nowrap;
    }

        .ga-btn:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

    .ga-btn-primary {
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.95), rgba(0, 200, 255, 0.75));
        border: 1px solid rgba(124, 92, 255, 0.30);
        color: #0b0f1a;
        font-weight: 700;
    }

    .ga-btn-danger {
        background: rgba(255, 77, 77, 0.12);
        border: 1px solid rgba(255, 77, 77, 0.25);
        color: rgba(255, 190, 190, 0.95);
    }

    .ga-spinner {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid rgba(0,0,0,0.25);
        border-top-color: rgba(0,0,0,0.75);
        display: inline-block;
        animation: gaspin 0.8s linear infinite;
    }

    @@keyframes gaspin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 860px) {
        .ga-grid {
            grid-template-columns: 1fr;
        }
    }
</style>