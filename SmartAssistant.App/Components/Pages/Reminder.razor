    .rm-btn {
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        cursor: pointer;
        background: rgba(255, 255, 255, 0.06);
        color: rgba(232, 236, 255, 0.90);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        user-select: none;
        white-space: nowrap;
    }

        .rm-btn:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

    .rm-btn-primary {
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.95), rgba(0, 200, 255, 0.75));
        border: 1px solid rgba(124, 92, 255, 0.30);
        color: #0b0f1a;
        font-weight: 700;
    }

        .rm-btn-primary:hover:enabled {
            filter: brightness(1.05);
        }

    .rm-btn-ghost:hover:enabled {
        background: rgba(255, 255, 255, 0.10);
    }

    .rm-btn-danger {
        background: rgba(255, 77, 77, 0.12);
        border: 1px solid rgba(255, 77, 77, 0.25);
        color: rgba(255, 190, 190, 0.95);
        padding: 8px 10px;
