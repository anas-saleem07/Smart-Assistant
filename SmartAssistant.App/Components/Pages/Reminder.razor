@page "/reminders"
@inject HttpClient Http
@using System.Net.Http.Json
@inject NavigationManager Navigation

<div class="rm-page">
    <div class="rm-shell">

        <header class="rm-header">
            <div>
                <h1 class="rm-title">Reminders</h1>
                <p class="rm-subtitle">Keep track of what matters. Add, review, and manage your nearest reminders fast.</p>
            </div>

            <div class="rm-header-actions">
                <button class="rm-btn rm-btn-ghost" @onclick='() => Navigation.NavigateTo("/reminder-history")'>
                    View All Reminders
                </button>

                <div class="rm-pill">
                    <span class="rm-pill-dot"></span>
                    <span>@(isProcessing ? "Working..." : "Ready")</span>
                </div>
            </div>
        </header>

        <section class="rm-approval-host">
            <AutoReplyApprovalBar />
        </section>

        @if (!string.IsNullOrWhiteSpace(statusText))
        {
            <div class="rm-status @(isError ? "rm-status-error" : "rm-status-ok")">
                <span class="rm-status-icon">@(isError ? "!" : "OK")</span>
                <span class="rm-status-text">@statusText</span>
                <button class="rm-status-close" @onclick="ClearStatus">x</button>
            </div>
        }

        <section class="rm-card rm-form">
            <div class="rm-form-grid">

                <div class="rm-field">
                    <label class="rm-label">Title</label>
                    <input class="rm-input"
                           @bind="newReminder.Title"
                           placeholder="e.g., Pay electricity bill" />
                </div>

                <div class="rm-field">
                    <label class="rm-label">Description</label>
                    <input class="rm-input"
                           @bind="newReminder.Description"
                           placeholder="Optional details..." />
                </div>

                <div class="rm-field">
                    <label class="rm-label">Reminder Time</label>
                    <input class="rm-input"
                           type="datetime-local"
                           @bind="newReminder.ReminderTime"
                           @bind:format="yyyy-MM-ddTHH:mm" />
                </div>

                <div class="rm-actions">
                    <button class="rm-btn rm-btn-primary"
                            @onclick="AddReminder"
                            disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span class="rm-spinner"></span>
                            <span>Adding...</span>
                        }
                        else
                        {
                            <span>Add Reminder</span>
                        }
                    </button>

                    <button class="rm-btn rm-btn-ghost"
                            @onclick="LoadReminders"
                            disabled="@isProcessing">
                        Refresh
                    </button>
                </div>

            </div>
        </section>

        <section class="rm-list">
            <div class="rm-list-header">
                <h2 class="rm-list-title">Upcoming Pending Reminders</h2>
                <span class="rm-count">@visibleReminders.Count</span>
            </div>

            @if (visibleReminders.Count == 0)
            {
                <div class="rm-empty rm-card">
                    <div class="rm-empty-icon">Time</div>

                    <div>
                        <div class="rm-empty-title">No pending reminders for the next three days</div>
                        <div class="rm-empty-sub">Completed and older reminders are available in Reminder History.</div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var group in groupedVisibleReminders)
                {
                    <section class="rm-group-section">
                        <div class="rm-group-header">
                            <h3 class="rm-group-title">@group.Title</h3>
                            <span class="rm-count">@group.Items.Count</span>
                        </div>

                        <div class="rm-grid">
                            @foreach (var reminder in group.Items)
                            {
                                var canMarkComplete = CanMarkComplete(reminder);

                                <article class="rm-item rm-card @(reminder.Completed ? "rm-item-completed" : "")">
                                    <div class="rm-item-top">
                                        <div class="rm-item-title">@GetReminderHeading(reminder)</div>

                                        <div class="rm-item-actions">
                                            @if (!reminder.Completed)
                                            {
                                                <button class="rm-btn rm-btn-success"
                                                        @onclick="() => UpdateReminderStatus(reminder.Id, true)"
                                                        disabled="@(!canMarkComplete || isProcessing)">
                                                    Complete
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="rm-btn rm-btn-ghost"
                                                        @onclick="() => UpdateReminderStatus(reminder.Id, false)"
                                                        disabled="@isProcessing">
                                                    Mark Incomplete
                                                </button>
                                            }

                                            <button class="rm-btn rm-btn-danger"
                                                    @onclick="() => DeleteReminder(reminder.Id)"
                                                    disabled="@isProcessing">
                                                Delete
                                            </button>
                                        </div>
                                    </div>

                                    <div class="rm-simple-list">
                                        <div class="rm-simple-row">
                                            <div class="rm-simple-label">From</div>
                                            <div class="rm-simple-value">@GetCleanFromText(reminder)</div>
                                        </div>

                                        <div class="rm-simple-row">
                                            <div class="rm-simple-label">Where</div>
                                            <div class="rm-simple-value">@GetCleanWhereText(reminder)</div>
                                        </div>

                                        <div class="rm-simple-row">
                                            <div class="rm-simple-label">Time</div>
                                            <div class="rm-simple-value">@GetCleanTimeText(reminder)</div>
                                        </div>
                                    </div>

                                    <div class="rm-item-meta">
                                        <span class="rm-badge @(reminder.Completed ? "rm-badge-completed" : "rm-badge-pending")">
                                            @(reminder.Completed ? "Completed" : "Pending")
                                        </span>

                                        <span class="rm-meta-sep">•</span>

                                        <span>@reminder.ReminderTimeLocalText</span>
                                    </div>

                                    @if (!reminder.Completed && !canMarkComplete)
                                    {
                                        <div class="rm-note">
                                            This reminder can be completed only after its due time is reached.
                                        </div>
                                    }
                                </article>
                            }
                        </div>
                    </section>
                }
            }
        </section>

    </div>
</div>

@code {
    private bool isProcessing;
    private string statusText = "";
    private bool isError;

    private List<ReminderDto> reminders = new();
    private List<ReminderDto> visibleReminders = new();
    private List<ReminderGroupVm> groupedVisibleReminders = new();

    private CreateReminderRequest newReminder = new()
    {
        ReminderTime = DateTime.Now
    };

    #region Private Methods

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var gmailStatus = await Http.GetFromJsonAsync<GoogleConnectionStatusModel>(
                "api/google-oauth/status",
                cancellationTokenSource.Token);

            if (gmailStatus?.IsConnected != true)
            {
                Navigation.NavigateTo("/google-auth");
                return;
            }

            await LoadReminders();
            ShowSettingsUpdatedMessageIfNeeded();
        }
        catch
        {
            Navigation.NavigateTo("/google-auth");
        }
    }

    private void ClearStatus()
    {
        statusText = "";
        isError = false;
    }

    private void SetStatus(string message, bool error)
    {
        statusText = message;
        isError = error;
    }

    private void ShowSettingsUpdatedMessageIfNeeded()
    {
        var currentUri = Navigation.ToAbsoluteUri(Navigation.Uri);

        if (string.IsNullOrWhiteSpace(currentUri.Query))
            return;

        if (currentUri.Query.Contains("settingsUpdated=1", StringComparison.OrdinalIgnoreCase))
        {
            SetStatus("Settings updated successfully.", false);
            Navigation.NavigateTo("/reminders", false);
        }
    }

    private async Task LoadReminders()
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            reminders =
                await Http.GetFromJsonAsync<List<ReminderDto>>(
                    "api/reminder/list",
                    cancellationTokenSource.Token)
                ?? new List<ReminderDto>();

            BuildVisibleReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while loading reminders.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to load reminders: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BuildVisibleReminders()
    {
        var today = DateTime.Now.Date;
        var tomorrow = today.AddDays(1);
        var dayAfterTomorrow = today.AddDays(2);

        visibleReminders = reminders
            .Where(reminder =>
            {
                if (reminder.Completed)
                    return false;

                var localDate = reminder.ReminderTime.ToLocalTime().Date;

                return localDate == today
                    || localDate == tomorrow
                    || localDate == dayAfterTomorrow;
            })
            .OrderBy(reminder => reminder.ReminderTime.ToLocalTime().Date)
            .ThenBy(reminder => reminder.ReminderTime)
            .ToList();

        groupedVisibleReminders = visibleReminders
            .GroupBy(reminder => GetMainScreenGroupTitle(reminder))
            .Select(group => new ReminderGroupVm
            {
                Title = group.Key,
                Items = group
                    .OrderBy(reminder => reminder.ReminderTime)
                    .ToList()
            })
            .OrderBy(group => group.SortOrder)
            .ToList();
    }

    private string GetMainScreenGroupTitle(ReminderDto reminder)
    {
        var localDate = reminder.ReminderTime.ToLocalTime().Date;
        var today = DateTime.Now.Date;
        var tomorrow = today.AddDays(1);
        var dayAfterTomorrow = today.AddDays(2);

        if (localDate == today)
            return "Today";

        if (localDate == tomorrow)
            return "Tomorrow";

        if (localDate == dayAfterTomorrow)
            return "Day After Tomorrow";

        return localDate.ToString("dddd, dd MMM yyyy");
    }

    private bool CanMarkComplete(ReminderDto reminder)
    {
        return reminder.ReminderTime <= DateTimeOffset.UtcNow;
    }

    private async Task UpdateReminderStatus(Guid reminderId, bool completed)
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.PutAsJsonAsync(
                $"api/reminder/status/{reminderId}",
                new UpdateReminderStatusRequest { Completed = completed },
                cancellationTokenSource.Token);

            var responseBody = await response.Content.ReadAsStringAsync(cancellationTokenSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Status update failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus(completed ? "Reminder marked as completed." : "Reminder marked as incomplete.", false);

            await LoadReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while updating reminder status.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to update reminder status: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddReminder()
    {
        if (isProcessing)
            return;

        if (string.IsNullOrWhiteSpace(newReminder.Title))
        {
            SetStatus("Title is required.", true);
            return;
        }

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.PostAsJsonAsync(
                "api/reminder/create",
                newReminder,
                cancellationTokenSource.Token);

            var responseBody = await response.Content.ReadAsStringAsync(cancellationTokenSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Create failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus("Reminder added successfully.", false);

            newReminder = new CreateReminderRequest
            {
                ReminderTime = DateTime.Now
            };

            await LoadReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while adding reminder.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to add reminder: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteReminder(Guid reminderId)
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.DeleteAsync(
                $"api/reminder/delete/{reminderId}",
                cancellationTokenSource.Token);

            var responseBody = await response.Content.ReadAsStringAsync(cancellationTokenSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Delete failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus("Reminder deleted.", false);

            await LoadReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while deleting reminder.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to delete reminder: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetReminderHeading(ReminderDto reminder)
    {
        if (string.IsNullOrWhiteSpace(reminder.Title))
            return "Interview reminder";

        var title = reminder.Title.Trim();

        if (title.StartsWith("Re:", StringComparison.OrdinalIgnoreCase))
            title = title[3..].Trim();

        var atTimeIndex = title.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
        if (atTimeIndex > 0)
            title = title[..atTimeIndex].Trim();

        return string.IsNullOrWhiteSpace(title) ? "Interview reminder" : title;
    }

    private string GetCleanFromText(ReminderDto reminder)
    {
        var combinedText = ((reminder.Title ?? "") + " " + (reminder.Description ?? "")).Trim();

        var emailMatch = System.Text.RegularExpressions.Regex.Match(
            combinedText,
            @"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}");

        var emailText = emailMatch.Success ? emailMatch.Value : "";

        var nameMatch = System.Text.RegularExpressions.Regex.Match(
            combinedText,
            @"From:\s*([^<\r\n]+)",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        var nameText = nameMatch.Success ? nameMatch.Groups[1].Value.Trim() : "";

        if (string.IsNullOrWhiteSpace(nameText) && !string.IsNullOrWhiteSpace(reminder.Title))
        {
            var title = reminder.Title.Trim();

            var parenthesisStartIndex = title.LastIndexOf('(');
            var parenthesisEndIndex = title.LastIndexOf(')');

            if (parenthesisStartIndex >= 0 && parenthesisEndIndex > parenthesisStartIndex)
            {
                var possibleEmail = title[(parenthesisStartIndex + 1)..parenthesisEndIndex].Trim();
                if (possibleEmail.Contains("@", StringComparison.OrdinalIgnoreCase))
                    emailText = possibleEmail;
            }
        }

        if (!string.IsNullOrWhiteSpace(emailText))
        {
            var emailName = emailText.Split('@')[0]
                .Replace(".", " ")
                .Replace("_", " ")
                .Trim();

            var readableEmailName = ToTitleCaseSafe(emailName);

            if (!string.IsNullOrWhiteSpace(nameText))
                return $"{nameText} ({emailText})";

            return $"{readableEmailName} ({emailText})";
        }

        if (!string.IsNullOrWhiteSpace(nameText))
            return nameText;

        return "Not available";
    }

    private string GetCleanWhereText(ReminderDto reminder)
    {
        if (string.IsNullOrWhiteSpace(reminder.Title))
            return "Not available";

        var title = reminder.Title.Trim();

        var fromIndex = title.IndexOf(" from ", StringComparison.OrdinalIgnoreCase);
        if (fromIndex >= 0)
        {
            var companyText = title[(fromIndex + 6)..].Trim();

            var atTimeIndex = companyText.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
            if (atTimeIndex > 0)
                companyText = companyText[..atTimeIndex].Trim();

            var onIndex = companyText.IndexOf(" on ", StringComparison.OrdinalIgnoreCase);
            if (onIndex > 0)
                companyText = companyText[..onIndex].Trim();

            if (!string.IsNullOrWhiteSpace(companyText))
                return companyText;
        }

        if (title.Contains("Interview Alert", StringComparison.OrdinalIgnoreCase))
            return "Interview Alert";

        return "Not available";
    }

    private string GetCleanTimeText(ReminderDto reminder)
    {
        if (!string.IsNullOrWhiteSpace(reminder.Title))
        {
            var title = reminder.Title.Trim();

            var atTimeIndex = title.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
            if (atTimeIndex >= 0)
            {
                var timeText = title[(atTimeIndex + 3)..].Trim();

                var parenthesisStartIndex = timeText.LastIndexOf('(');
                if (parenthesisStartIndex > 0)
                    timeText = timeText[..parenthesisStartIndex].Trim();

                return timeText;
            }
        }

        if (!string.IsNullOrWhiteSpace(reminder.ReminderTimeLocalText))
            return reminder.ReminderTimeLocalText;

        return "Not available";
    }

    private string ToTitleCaseSafe(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(word => char.ToUpperInvariant(word[0]) + word[1..].ToLowerInvariant());

        return string.Join(" ", words);
    }

    #endregion

    #region Models

    public sealed class CreateReminderRequest
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public DateTime ReminderTime { get; set; }
    }

    public sealed class ReminderDto
    {
        public Guid Id { get; set; }
        public string? Title { get; set; }
        public string? Description { get; set; }
        public DateTimeOffset ReminderTime { get; set; }
        public string ReminderTimeLocalText { get; set; } = "";
        public bool Completed { get; set; }
        public DateTime CreatedOn { get; set; }
    }

    public sealed class GoogleConnectionStatusModel
    {
        public bool IsConnected { get; set; }
        public bool NeedsReconnect { get; set; }
        public string Provider { get; set; } = "Gmail";
        public string Email { get; set; } = "";
        public string Message { get; set; } = "";
    }

    public sealed class UpdateReminderStatusRequest
    {
        public bool Completed { get; set; }
    }

    public sealed class ReminderGroupVm
    {
        public string Title { get; set; } = "";
        public List<ReminderDto> Items { get; set; } = new();

        public int SortOrder
        {
            get
            {
                if (Title == "Today")
                    return 1;

                if (Title == "Tomorrow")
                    return 2;

                if (Title == "Day After Tomorrow")
                    return 3;

                return 99;
            }
        }
    }

    #endregion
}

<style>
    .rm-page {
        min-height: 100vh;
        background: radial-gradient(1200px 800px at 20% 10%, rgba(120, 90, 255, 0.18), transparent 55%), radial-gradient(1000px 700px at 80% 30%, rgba(0, 200, 255, 0.10), transparent 55%), linear-gradient(180deg, #0b0f1a 0%, #070a12 100%);
        color: #e8ecff;
        padding: 28px;
    }

