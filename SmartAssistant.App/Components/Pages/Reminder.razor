            box-shadow: 0 22px 44px rgba(0, 0, 0, 0.38), 0 8px 20px rgba(0, 0, 0, 0.24), 0 0 28px rgba(0, 200, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.14);
        }

    .rm-item-completed {
        opacity: 0.78;
    }

    .rm-status {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 14px;
        border-radius: 14px;
    }

    .rm-status-ok {
        border: 1px solid rgba(0, 255, 163, 0.25);
        background: rgba(0, 255, 163, 0.08);
    }

    .rm-status-error {
        border: 1px solid rgba(255, 77, 77, 0.30);
        background: rgba(255, 77, 77, 0.10);
    }

    .rm-status-icon {
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.18);
        font-weight: 700;
    }

    .rm-status-text {
        flex: 1;
        color: rgba(232, 236, 255, 0.92);
    }

    .rm-status-close {
