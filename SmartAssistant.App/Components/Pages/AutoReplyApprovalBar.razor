    }

    .ar-status-close {
        background: transparent;
        border: none;
        color: #fff;
        cursor: pointer;
        font-size: 16px;
    }

    @@media (max-width: 860px) {
        .ar-actions {
            flex-direction: column;
        }
    }
</style>