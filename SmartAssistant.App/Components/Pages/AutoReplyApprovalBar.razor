@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.Maui.ApplicationModel
@inject HttpClient Http
@inject NavigationManager Nav
@implements IDisposable

@if (!string.IsNullOrWhiteSpace(statusText))
{
    <div class="ar-status @(isError ? "ar-status-error" : "ar-status-ok")">
        <span>@statusText</span>
        <button class="ar-status-close" @onclick="ClearStatus">X</button>
    </div>
}

@if (pendingItems.Count > 0)
{
    <section class="ar-wrap">
        <div class="ar-head">
            <div>
                <h2 class="ar-title">Pending auto reply approvals</h2>
                <p class="ar-subtitle">Review after-hours meeting requests and respond instantly.</p>
            </div>

            <div class="ar-count">@pendingItems.Count</div>
        </div>

        @foreach (var pendingItem in pendingItems)
        {
            <article class="ar-card">
                <div class="ar-card-top">
                    <div class="ar-badge">Approval needed</div>
                    <div class="ar-id">#@pendingItem.Id</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(pendingItem.Subject))
                {
                    <div class="ar-subject">
                        @GetCleanSubjectText(pendingItem)
                    </div>
                }

                <div class="ar-simple-list">

                    <div class="ar-simple-row">
                        <div class="ar-simple-label">From</div>
                        <div class="ar-simple-value">@GetFromDisplayText(pendingItem)</div>
                    </div>

                    <div class="ar-simple-row">
                        <div class="ar-simple-label">Time</div>
                        <div class="ar-simple-value">@GetScheduleAndSuggestedText(pendingItem)</div>
                    </div>

                    <div class="ar-simple-row">
                        <div class="ar-simple-label">Reason</div>
                        <div class="ar-simple-value">@GetReasonText(pendingItem)</div>
                    </div>

                </div>

                <div class="ar-actions">
                    <button class="ar-btn ar-btn-yes"
                            @onclick="() => ApproveSameSlot(pendingItem)"
                            disabled="@(activeActionId == pendingItem.Id || !pendingItem.ProposedStartUtc.HasValue)">
                        @(activeActionId == pendingItem.Id ? "Working..." : "Yes")
                    </button>

                    <button class="ar-btn ar-btn-suggest"
                            @onclick="() => OpenGoogleCalendarForSuggestedSlot(pendingItem)"
                            disabled="@(activeActionId == pendingItem.Id)">
                        Suggest time slot
                    </button>

                    <button class="ar-btn ar-btn-confirm"
                            @onclick="() => SendSuggestedSlot(pendingItem)"
                            disabled="@(activeActionId == pendingItem.Id || !pendingItem.SuggestedStartUtc.HasValue)">
                        Send reschedule email
                    </button>

                    <button class="ar-btn ar-btn-no"
                            @onclick="() => RejectRequest(pendingItem)"
                            disabled="@(activeActionId == pendingItem.Id)">
                        No
                    </button>
                </div>
            </article>
        }
    </section>
}

@code {
    private bool isError;
    private string statusText = "";
    private List<PendingAutoReplyViewModel> pendingItems = new();
    private PeriodicTimer? refreshTimer;
    private CancellationTokenSource? refreshCancellationSource;
    private long? activeActionId;

    #region Lifecycle

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingApprovals();

        refreshCancellationSource = new CancellationTokenSource();
        refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));

        _ = RunRefreshLoopAsync(refreshCancellationSource.Token);
    }

    public void Dispose()
    {
        refreshCancellationSource?.Cancel();
        refreshTimer?.Dispose();
        refreshCancellationSource?.Dispose();
    }

    #endregion

    #region Private Methods

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (refreshTimer != null && await refreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                if (!activeActionId.HasValue)
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadPendingApprovals();
                        StateHasChanged();
                    });
                }
            }
        }
        catch
        {
        }
    }

    private async Task LoadPendingApprovals()
    {
        try
        {
            using var timeoutSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.GetAsync(
                "api/auto-reply/pending",
                timeoutSource.Token);

            if (await RedirectIfReconnectRequiredAsync(response, timeoutSource.Token))
                return;

            var responseBody = await response.Content.ReadAsStringAsync(timeoutSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Failed to load pending approvals ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            pendingItems = JsonSerializer.Deserialize<List<PendingAutoReplyViewModel>>(
                responseBody,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }) ?? new List<PendingAutoReplyViewModel>();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while loading pending approvals.", true);
        }
        catch (Exception exception)
        {
            SetStatus("Failed to load pending approvals: " + exception.Message, true);
        }
    }

    private async Task ApproveSameSlot(PendingAutoReplyViewModel item)
    {
        await SendSimpleActionAsync(
            item,
            $"api/auto-reply/approve-same-slot/{item.Id}",
            "Original slot approved. Reminder created and acceptance email sent.");
    }

    private async Task SendSuggestedSlot(PendingAutoReplyViewModel item)
    {
        await SendSimpleActionAsync(
            item,
            $"api/auto-reply/approve-suggested-slot/{item.Id}",
            "Reschedule email sent. The slot remains tentative until the other side confirms.");
    }

    private async Task RejectRequest(PendingAutoReplyViewModel item)
    {
        await SendSimpleActionAsync(
            item,
            $"api/auto-reply/reject/{item.Id}",
            "Request rejected.");
    }

    private async Task OpenGoogleCalendarForSuggestedSlot(PendingAutoReplyViewModel pendingItem)
    {
        if (activeActionId.HasValue)
            return;

        try
        {
            activeActionId = pendingItem.Id;
            ClearStatus();

            using var timeoutSource = new CancellationTokenSource(TimeSpan.FromSeconds(12));

            var response = await Http.PostAsJsonAsync(
                $"api/auto-reply/open-suggested-calendar/{pendingItem.Id}",
                new { },
                timeoutSource.Token);

            if (await RedirectIfReconnectRequiredAsync(response, timeoutSource.Token))
                return;

            var responseBody = await response.Content.ReadAsStringAsync(timeoutSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Action failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            var result = JsonSerializer.Deserialize<ApprovalCalendarOpenResponse>(
                responseBody,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

            if (result == null || !result.Success)
            {
                SetStatus(result?.Message ?? "Failed to create draft Google Calendar event.", true);
                return;
            }

            var suggestedTimeText = "";

            if (result.StartUtc.HasValue && result.EndUtc.HasValue)
            {
                suggestedTimeText = ToLocalRangeText(
                    result.StartUtc.Value,
                    result.EndUtc.Value,
                    "PKT");
            }
            else if (result.StartUtc.HasValue)
            {
                suggestedTimeText = ToLocalSingleText(
                    result.StartUtc.Value,
                    "PKT");
            }

            var statusMessage = string.IsNullOrWhiteSpace(suggestedTimeText)
                ? "Draft suggested slot saved successfully. It is not confirmed yet. Review or edit it in Google Calendar, then come back to the app and send the reschedule email."
                : "Draft suggested slot saved successfully for " + suggestedTimeText + ". It is not confirmed yet. Review or edit it in Google Calendar, then come back to the app and send the reschedule email.";

            SetStatus(statusMessage, false);

            await LoadPendingApprovals();
            await InvokeAsync(StateHasChanged);

            if (!string.IsNullOrWhiteSpace(result.EventHtmlLink))
            {
                await Launcher.Default.OpenAsync(result.EventHtmlLink);
            }
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while creating draft Google Calendar event.", true);
        }
        catch (Exception exception)
        {
            SetStatus("Failed to open Google Calendar: " + exception.Message, true);
        }
        finally
        {
            activeActionId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SendSimpleActionAsync(PendingAutoReplyViewModel item, string url, string successMessage)
    {
        if (activeActionId.HasValue)
            return;

        try
        {
            activeActionId = item.Id;
            ClearStatus();

            using var timeoutSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.PostAsJsonAsync(url, new { }, timeoutSource.Token);

            if (await RedirectIfReconnectRequiredAsync(response, timeoutSource.Token))
                return;

            var responseBody = await response.Content.ReadAsStringAsync(timeoutSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Action failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus(successMessage, false);
            await LoadPendingApprovals();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while sending the action.", true);
        }
        catch (Exception exception)
        {
            SetStatus("Action failed: " + exception.Message, true);
        }
        finally
        {
            activeActionId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> RedirectIfReconnectRequiredAsync(HttpResponseMessage response, CancellationToken cancellationToken)
    {
        if (response.StatusCode != HttpStatusCode.Unauthorized)
            return false;

        var raw = await response.Content.ReadAsStringAsync(cancellationToken);

        ApiErrorResponse? error = null;

        try
        {
            error = JsonSerializer.Deserialize<ApiErrorResponse>(
                raw,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
        }
        catch
        {
        }

        if (error?.Code == "gmail_reconnect_required")
        {
            Nav.NavigateTo("/gmail-reconnect");
            return true;
        }

        return false;
    }

    private void SetStatus(string message, bool error)
    {
        statusText = message;
        isError = error;
    }

    private void ClearStatus()
    {
        statusText = "";
        isError = false;
    }

    private string GetCleanSubjectText(PendingAutoReplyViewModel pendingItem)
    {
        if (string.IsNullOrWhiteSpace(pendingItem.Subject))
            return "Interview request";

        var subject = pendingItem.Subject.Trim();

        if (subject.StartsWith("Re:", StringComparison.OrdinalIgnoreCase))
            subject = subject[3..].Trim();

        return string.IsNullOrWhiteSpace(subject) ? "Interview request" : subject;
    }

    private string GetFromDisplayText(PendingAutoReplyViewModel pendingItem)
    {
        var cleanFrom = GetCleanFromText(pendingItem);
        var companyName = GetCompanyDisplayText(pendingItem);

        if (!string.IsNullOrWhiteSpace(companyName) &&
            !string.Equals(companyName, "Not available", StringComparison.OrdinalIgnoreCase))
        {
            return cleanFrom + " (" + companyName + ")";
        }

        return cleanFrom;
    }

    private string GetCleanFromText(PendingAutoReplyViewModel pendingItem)
    {
        var sourceText = ((pendingItem.From ?? "") + " " + (pendingItem.Subject ?? "")).Trim();

        var emailMatch = Regex.Match(
            sourceText,
            @"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}");

        var emailText = emailMatch.Success ? emailMatch.Value : "";

        var nameText = "";

        if (!string.IsNullOrWhiteSpace(pendingItem.From))
        {
            var fromText = pendingItem.From.Trim();

            var angleBracketIndex = fromText.IndexOf('<');
            if (angleBracketIndex > 0)
            {
                nameText = fromText[..angleBracketIndex].Trim().Trim('"');
            }
            else
            {
                var cleanedFrom = Regex.Replace(fromText, @"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}", "").Trim();
                cleanedFrom = cleanedFrom.Replace("<", "").Replace(">", "").Trim();

                if (!string.IsNullOrWhiteSpace(cleanedFrom))
                    nameText = cleanedFrom;
            }
        }

        if (string.IsNullOrWhiteSpace(nameText) && !string.IsNullOrWhiteSpace(emailText))
        {
            var emailName = emailText.Split('@')[0]
                .Replace(".", " ")
                .Replace("_", " ")
                .Trim();

            nameText = ToTitleCaseSafe(emailName);
        }

        if (!string.IsNullOrWhiteSpace(nameText) && !string.IsNullOrWhiteSpace(emailText))
            return $"{nameText} ({emailText})";

        if (!string.IsNullOrWhiteSpace(emailText))
            return emailText;

        if (!string.IsNullOrWhiteSpace(nameText))
            return nameText;

        return "Not available";
    }

    private string GetCompanyDisplayText(PendingAutoReplyViewModel pendingItem)
    {
        if (string.IsNullOrWhiteSpace(pendingItem.Subject))
            return "";

        var subject = pendingItem.Subject.Trim();

        var fromIndex = subject.IndexOf(" from ", StringComparison.OrdinalIgnoreCase);
        if (fromIndex >= 0)
        {
            var companyText = subject[(fromIndex + 6)..].Trim();

            var atIndex = companyText.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
            if (atIndex > 0)
                companyText = companyText[..atIndex].Trim();

            var onIndex = companyText.IndexOf(" on ", StringComparison.OrdinalIgnoreCase);
            if (onIndex > 0)
                companyText = companyText[..onIndex].Trim();

            companyText = companyText.Trim('(', ')', ' ');

            if (!string.IsNullOrWhiteSpace(companyText))
                return companyText;
        }

        return "";
    }

    private string GetScheduleAndSuggestedText(PendingAutoReplyViewModel pendingItem)
    {
        var lines = new List<string>();

        var scheduleText = GetScheduleTimeText(pendingItem);
        if (!string.IsNullOrWhiteSpace(scheduleText))
            lines.Add("Schedule Time: " + scheduleText);

        var suggestedText = GetSuggestedSlotText(pendingItem);
        if (!string.IsNullOrWhiteSpace(suggestedText))
            lines.Add("Suggested Slot: " + suggestedText);

        if (lines.Count == 0)
            return "Not available";

        return string.Join("\n", lines);
    }

    private string GetScheduleTimeText(PendingAutoReplyViewModel pendingItem)
    {
        if (!string.IsNullOrWhiteSpace(pendingItem.ProposedLocalText))
            return pendingItem.ProposedLocalText;

        if (pendingItem.ProposedStartUtc.HasValue && pendingItem.ProposedEndUtc.HasValue)
        {
            return ToLocalRangeText(
                pendingItem.ProposedStartUtc.Value,
                pendingItem.ProposedEndUtc.Value,
                "PKT");
        }

        return "";
    }

    private string GetSuggestedSlotText(PendingAutoReplyViewModel pendingItem)
    {
        if (!string.IsNullOrWhiteSpace(pendingItem.SuggestedLocalText))
            return pendingItem.SuggestedLocalText;

        if (pendingItem.SuggestedStartUtc.HasValue)
            return ToLocalSingleText(pendingItem.SuggestedStartUtc.Value, "PKT");

        return "";
    }

    private string GetReasonText(PendingAutoReplyViewModel pendingItem)
    {
        if (!string.IsNullOrWhiteSpace(pendingItem.RequestSummary))
            return pendingItem.RequestSummary.Trim();

        if (!string.IsNullOrWhiteSpace(pendingItem.ReplyLastError))
            return pendingItem.ReplyLastError.Trim();

        if (!string.IsNullOrWhiteSpace(GetSuggestedSlotText(pendingItem)))
            return "Requested time is outside office hours or conflicts with another reminder.";

        return "Approval required before sending auto reply.";
    }

    private string ToTitleCaseSafe(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(word => char.ToUpperInvariant(word[0]) + word[1..].ToLowerInvariant());

        return string.Join(" ", words);
    }

    private string ToLocalSingleText(DateTimeOffset utc, string timeZoneLabel)
    {
        var localTime = utc.ToLocalTime().DateTime;
        return localTime.ToString("dddd, MMM d, yyyy h:mm tt") + " " + timeZoneLabel;
    }

    private string ToLocalRangeText(DateTimeOffset startUtc, DateTimeOffset endUtc, string timeZoneLabel)
    {
        var startLocal = startUtc.ToLocalTime().DateTime;
        var endLocal = endUtc.ToLocalTime().DateTime;

        if (startLocal.Date == endLocal.Date)
        {
            return startLocal.ToString("dddd, MMM d, yyyy h:mm tt") +
                   " - " +
                   endLocal.ToString("h:mm tt") +
                   " " +
                   timeZoneLabel;
        }

        return startLocal.ToString("dddd, MMM d, yyyy h:mm tt") +
               " - " +
               endLocal.ToString("dddd, MMM d, yyyy h:mm tt") +
               " " +
               timeZoneLabel;
    }

    #endregion

    #region Models

    public sealed class ApiErrorResponse
    {
        public string Code { get; set; } = "";
        public string Message { get; set; } = "";
    }

    public sealed class PendingAutoReplyViewModel
    {
        public long Id { get; set; }
        public string Provider { get; set; } = "";
        public string MessageId { get; set; } = "";
        public string Subject { get; set; } = "";
        public string From { get; set; } = "";
        public string RequestSummary { get; set; } = "";
        public DateTimeOffset? ProposedStartUtc { get; set; }
        public DateTimeOffset? ProposedEndUtc { get; set; }
        public string ProposedLocalText { get; set; } = "";
        public string SuggestedLocalText { get; set; } = "";
        public DateTimeOffset? SuggestedStartUtc { get; set; }
        public string? ReplyLastError { get; set; }
    }

    public sealed class ApprovalCalendarOpenResponse
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public string EventHtmlLink { get; set; } = "";
        public string EventId { get; set; } = "";
        public DateTimeOffset? StartUtc { get; set; }
        public DateTimeOffset? EndUtc { get; set; }
    }

    #endregion
}

<style>
