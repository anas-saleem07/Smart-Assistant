        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255, 196, 0, 0.14);
        border: 1px solid rgba(255, 196, 0, 0.26);
        color: #ffe6a3;
        font-size: 12px;
        font-weight: 700;
    }

    .ar-id {
        color: rgba(232, 236, 255, 0.60);
        font-size: 12px;
    }

    .ar-subject {
        font-size: 18px;
        font-weight: 800;
        line-height: 1.35;
