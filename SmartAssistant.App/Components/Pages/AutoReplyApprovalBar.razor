        margin: 0 0 18px 0;
        padding: 18px;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(255, 179, 0, 0.10), rgba(255, 179, 0, 0.05));
        border: 1px solid rgba(255, 196, 0, 0.22);
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.26);
        backdrop-filter: blur(12px);
    }

