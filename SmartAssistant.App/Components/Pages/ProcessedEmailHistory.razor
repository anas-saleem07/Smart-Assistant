        background: rgba(0, 255, 163, 0.08);
    }

    .rm-status-error {
        border: 1px solid rgba(255, 77, 77, 0.30);
        background: rgba(255, 77, 77, 0.10);
    }

    .rm-status-icon {
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.18);
        font-weight: 700;
    }

    .rm-status-text {
        flex: 1;
        color: rgba(232, 236, 255, 0.92);
    }

    .rm-status-close {
        border: none;
        background: transparent;
        color: rgba(232, 236, 255, 0.70);
        font-size: 18px;
        cursor: pointer;
    }

    .rm-filter-card {
        padding: 14px;
        margin-bottom: 18px;
    }

    .rm-filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .rm-chip {
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        color: rgba(232, 236, 255, 0.88);
        cursor: pointer;
    }

    .rm-chip-active {
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.95), rgba(0, 200, 255, 0.75));
        color: #0b0f1a;
        border-color: rgba(124, 92, 255, 0.30);
        font-weight: 700;
    }

    .rm-btn {
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        cursor: pointer;
        background: rgba(255, 255, 255, 0.06);
        color: rgba(232, 236, 255, 0.90);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        user-select: none;
        white-space: nowrap;
    }

        .rm-btn:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

    .rm-btn-ghost:hover:enabled {
        background: rgba(255, 255, 255, 0.10);
    }

    .rm-list-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
