        border: 1px solid rgba(124, 92, 255, 0.26);
        font-size: 20px;
    }

    .rm-empty-title {
        font-weight: 800;
        color: rgba(232, 236, 255, 0.95);
    }

    .rm-empty-sub {
        color: rgba(232, 236, 255, 0.68);
        margin-top: 4px;
        font-size: 13px;
    }

    @@media (max-width: 860px) {
        .rm-header {
            flex-direction: column;
        }

        .rm-header-actions {
            width: 100%;
            justify-content: flex-start;
        }
    }
</style>