    }

    .rm-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.10);
        color: rgba(232, 236, 255, 0.85);
        user-select: none;
        white-space: nowrap;
    }

    .rm-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #7c5cff;
        box-shadow: 0 0 12px rgba(124, 92, 255, 0.85);
    }

    .rm-card {
        background: var(--card);
        border: 1px solid var(--cardBorder);
        border-radius: 16px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34), 0 6px 18px rgba(0, 0, 0, 0.22), 0 0 0 1px rgba(255, 255, 255, 0.02) inset, 0 0 24px rgba(124, 92, 255, 0.08);
