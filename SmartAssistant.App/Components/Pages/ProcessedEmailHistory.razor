        margin: 0;
        font-size: 18px;
        color: rgba(232, 236, 255, 0.92);
    }

    .rm-table-wrap {
        overflow-x: auto;
    }

    .rm-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
    }

        .rm-table thead th {
            text-align: left;
