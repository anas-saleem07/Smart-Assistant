        justify-content: center;
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.22), rgba(0, 200, 255, 0.16));
        border: 1px solid rgba(255, 255, 255, 0.10);
        font-size: 28px;
        font-weight: 800;
        color: #f6f8ff;
    }

    .gr-content {
        flex: 1;
    }

    .gr-card-title {
        margin: 0 0 10px;
        font-size: 24px;
        font-weight: 800;
        color: rgba(245, 247, 255, 0.98);
    }

    .gr-card-text {
        margin: 0 0 18px;
        color: rgba(232, 236, 255, 0.74);
        line-height: 1.7;
    }

    .gr-actions {
        display: flex;
        gap: 10px;
