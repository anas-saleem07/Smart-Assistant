@page "/reschedule-cancelled-history"
@inject HttpClient Http
@using System.Net.Http.Json
@inject NavigationManager Navigation

<div class="rm-page">
    <div class="rm-shell rm-shell-wide">
        <header class="rm-header">
            <div>
                <h1 class="rm-title">Scheduler Activity Log History</h1>
                <p class="rm-subtitle">Track rescheduled and cancelled scheduling email outcomes.</p>
                <div class="rm-soft-delete-note">Cancelled records are kept as Soft Deleted for audit history.</div>
            </div>

            <div class="rm-header-actions">
                <button class="rm-btn rm-btn-ghost rm-btn-small" @onclick='() => Navigation.NavigateTo("/reminder-history")'>
                    Back to Reminder History
                </button>
                <div class="rm-pill">
                    <span class="rm-pill-dot"></span>
                    <span>@(isProcessing ? "Working..." : "Ready")</span>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(statusText))
        {
            <div class="rm-status @(isError ? "rm-status-error" : "rm-status-ok")">
                <span class="rm-status-icon">@(isError ? "!" : "OK")</span>
                <span class="rm-status-text">@statusText</span>
                <button class="rm-status-close" @onclick="ClearStatus">x</button>
            </div>
        }

        <section class="rm-card rm-filter-card">
            <div class="rm-filter-row">
                <button class="rm-chip @(selectedFilter == HistoryFilter.All ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(HistoryFilter.All)'>
                    All
                </button>
                <button class="rm-chip @(selectedFilter == HistoryFilter.Rescheduled ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(HistoryFilter.Rescheduled)'>
                    Rescheduled
                </button>
                <button class="rm-chip @(selectedFilter == HistoryFilter.Cancelled ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(HistoryFilter.Cancelled)'>
                    Cancelled
                </button>
                <button class="rm-btn rm-btn-ghost" @onclick="LoadHistory" disabled="@isProcessing">
                    Refresh
                </button>
            </div>
        </section>

        <section class="rm-list">
            <div class="rm-list-header">
                <h2 class="rm-list-title">Email Outcome History</h2>
                <span class="rm-count">@filteredItems.Count</span>
            </div>

            @if (filteredItems.Count == 0)
            {
                <div class="rm-empty rm-card">
                    <div class="rm-empty-icon">Mail</div>
                    <div>
                        <div class="rm-empty-title">No records found</div>
                        <div class="rm-empty-sub">Try another filter or refresh.</div>
                    </div>
                </div>
            }
            else
            {
                <div class="rm-table-wrap rm-card">
                    <table class="rm-table">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Details</th>
                                <th>Processed Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in filteredItems)
                            {
                                <tr>
                                    <td>@GetSubjectText(item)</td>
                                    <td>
                                        <span class="rm-badge @GetStatusBadgeClass(item.ProcessingStatus)">
                                            @GetStatusLabel(item.ProcessingStatus)
                                        </span>
                                    </td>
                                    <td>@GetDetailsText(item)</td>
                                    <td>@item.ProcessedOn.ToLocalTime().ToString("ddd, dd MMM yyyy hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private bool isProcessing;
    private string statusText = "";
    private bool isError;
    private HistoryFilter selectedFilter = HistoryFilter.All;
    private List<ProcessedEmailHistoryDto> items = new();
    private List<ProcessedEmailHistoryDto> filteredItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private void ClearStatus()
    {
        statusText = "";
        isError = false;
    }

    private void SetStatus(string message, bool error)
    {
        statusText = message;
        isError = error;
    }

    private async Task LoadHistory()
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var allItems =
                await Http.GetFromJsonAsync<List<ProcessedEmailHistoryDto>>(
                    "api/auto-reply/history",
                    cancellationTokenSource.Token)
                ?? new List<ProcessedEmailHistoryDto>();

            items = allItems
                .Where(item => IsRescheduledStatus(item.ProcessingStatus) || IsCancelledStatus(item.ProcessingStatus))
                .OrderByDescending(item => item.ProcessedOn)
                .ToList();

            ApplyFilter();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while loading history.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to load history: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ChangeFilter(HistoryFilter filter)
    {
        selectedFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        IEnumerable<ProcessedEmailHistoryDto> query = items;

        if (selectedFilter == HistoryFilter.Rescheduled)
            query = query.Where(item => IsRescheduledStatus(item.ProcessingStatus));
        else if (selectedFilter == HistoryFilter.Cancelled)
            query = query.Where(item => IsCancelledStatus(item.ProcessingStatus));

        filteredItems = query.OrderByDescending(item => item.ProcessedOn).ToList();
    }

    private static bool IsRescheduledStatus(string? status)
    {
        return string.Equals(status, "ReschedulePending", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsCancelledStatus(string? status)
    {
        return string.Equals(status, "RejectedBySender", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(status, "RejectedByUser", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetStatusLabel(string? status)
    {
        return status switch
        {
            "ReschedulePending" => "Rescheduled",
            "RejectedBySender" => "Soft Deleted (Cancelled by Sender)",
            "RejectedByUser" => "Soft Deleted (Cancelled by User)",
            _ => "Unknown"
        };
    }

    private static string GetStatusBadgeClass(string? status)
    {
        return status switch
        {
            "ReschedulePending" => "rm-badge-pending",
            "RejectedBySender" => "rm-badge-error",
            "RejectedByUser" => "rm-badge-error",
            _ => "rm-badge-pending"
        };
    }

    private static string GetSubjectText(ProcessedEmailHistoryDto item)
    {
        return string.IsNullOrWhiteSpace(item.Subject) ? "Scheduling email" : item.Subject;
    }

    private static string GetDetailsText(ProcessedEmailHistoryDto item)
    {
        return string.IsNullOrWhiteSpace(item.Details) ? "-" : item.Details;
    }

    public sealed class ProcessedEmailHistoryDto
    {
        public long Id { get; set; }
        public string Subject { get; set; } = "";
        public string ProcessingStatus { get; set; } = "";
        public string Details { get; set; } = "";
        public DateTimeOffset ProcessedOn { get; set; }
    }

    public enum HistoryFilter
    {
        All = 1,
        Rescheduled = 2,
        Cancelled = 3
    }
}

<style>
    .rm-page {
        min-height: 100vh;
        background: radial-gradient(1200px 800px at 20% 10%, rgba(120, 90, 255, 0.18), transparent 55%), radial-gradient(1000px 700px at 80% 30%, rgba(0, 200, 255, 0.10), transparent 55%), linear-gradient(180deg, #0b0f1a 0%, #070a12 100%);
