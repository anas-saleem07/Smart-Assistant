        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.10);
    }

    .rm-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #7c5cff;
    }

    .rm-card {
        background: var(--card);
        border: 1px solid var(--cardBorder);
        border-radius: 16px;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34);
    }

    .rm-filter-card {
        padding: 14px;
        margin-bottom: 18px;
    }

    .rm-filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .rm-chip {
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        color: rgba(232, 236, 255, 0.88);
        cursor: pointer;
    }

