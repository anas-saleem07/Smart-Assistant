    .rm-btn {
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        color: rgba(232, 236, 255, 0.90);
        cursor: pointer;
    }

    .rm-btn-small {
        padding: 8px 10px;
        font-size: 13px;
    }

    .rm-status {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 14px;
        border-radius: 14px;
    }

    .rm-status-ok {
        border: 1px solid rgba(0, 255, 163, 0.25);
        background: rgba(0, 255, 163, 0.08);
    }

    .rm-status-error {
        border: 1px solid rgba(255, 77, 77, 0.30);
        background: rgba(255, 77, 77, 0.10);
    }

    .rm-status-close {
        border: none;
        background: transparent;
        color: rgba(232, 236, 255, 0.70);
        font-size: 18px;
        cursor: pointer;
    }

    .rm-list-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 8px 0 12px;
