    .rm-badge {
        padding: 5px 10px;
        border-radius: 999px;
        display: inline-block;
    }

    .rm-badge-pending {
        background: rgba(124, 92, 255, 0.16);
        border: 1px solid rgba(124, 92, 255, 0.28);
    }

    .rm-badge-error {
