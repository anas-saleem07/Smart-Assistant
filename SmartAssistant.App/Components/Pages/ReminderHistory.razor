@page "/reminder-history"
@inject HttpClient Http
@using System.Net.Http.Json
@inject NavigationManager Navigation

<div class="rm-page">
    <div class="rm-shell rm-shell-wide">

        <header class="rm-header">
            <div>
                <h1 class="rm-title">Reminder History</h1>
                <p class="rm-subtitle">Review pending and completed reminders in a cleaner, more detailed history view.</p>
            </div>

            <div class="rm-header-actions">
                <button class="rm-btn rm-btn-ghost" @onclick='() => Navigation.NavigateTo("/reminders")'>
                    Back to Main Reminders
                </button>

                <div class="rm-pill">
                    <span class="rm-pill-dot"></span>
                    <span>@(isProcessing ? "Working..." : "Ready")</span>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(statusText))
        {
            <div class="rm-status @(isError ? "rm-status-error" : "rm-status-ok")">
                <span class="rm-status-icon">@(isError ? "!" : "OK")</span>
                <span class="rm-status-text">@statusText</span>
                <button class="rm-status-close" @onclick="ClearStatus">x</button>
            </div>
        }

        <section class="rm-card rm-filter-card">
            <div class="rm-filter-row">
                <button class="rm-chip @(selectedFilter == ReminderFilter.All ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(ReminderFilter.All)'>
                    All
                </button>

                <button class="rm-chip @(selectedFilter == ReminderFilter.Incomplete ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(ReminderFilter.Incomplete)'>
                    Incomplete
                </button>

                <button class="rm-chip @(selectedFilter == ReminderFilter.Completed ? "rm-chip-active" : "")"
                        @onclick='() => ChangeFilter(ReminderFilter.Completed)'>
                    Completed
                </button>

                <button class="rm-btn rm-btn-ghost" @onclick="LoadReminders" disabled="@isProcessing">
                    Refresh
                </button>
            </div>
        </section>

        <section class="rm-list">
            <div class="rm-list-header">
                <h2 class="rm-list-title">Reminder Table</h2>
                <span class="rm-count">@filteredReminders.Count</span>
            </div>

            @if (filteredReminders.Count == 0)
            {
                <div class="rm-empty rm-card">
                    <div class="rm-empty-icon">Time</div>
                    <div>
                        <div class="rm-empty-title">No reminders found</div>
                        <div class="rm-empty-sub">Try another filter or add more reminders.</div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var group in groupedReminders)
                {
                    <section class="rm-group-section">
                        <div class="rm-group-header">
                            <h3 class="rm-group-title">@group.Title</h3>
                            <span class="rm-count">@group.Items.Count</span>
                        </div>

                        <div class="rm-table-wrap rm-card">
                            <table class="rm-table">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th>Title</th>
                                        <th>Description</th>
                                        <th>Reminder Time</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reminder in group.Items)
                                    {
                                        var canMarkComplete = CanMarkComplete(reminder);

                                        <tr class="@(reminder.Completed ? "rm-row-completed" : "")">
                                            <td>
                                                <span class="rm-badge @(reminder.Completed ? "rm-badge-completed" : "rm-badge-pending")">
                                                    @(reminder.Completed ? "Completed" : "Pending")
                                                </span>
                                            </td>
                                            <td>@GetReminderHeading(reminder)</td>
                                            <td>@BuildHistoryDescription(reminder)</td>
                                            <td>@reminder.ReminderTimeLocalText</td>
                                            <td>
                                                <div class="rm-table-actions">
                                                    @if (!reminder.Completed)
                                                    {
                                                        <button class="rm-btn rm-btn-success rm-btn-table"
                                                                @onclick="() => UpdateReminderStatus(reminder.Id, true)"
                                                                disabled="@(!canMarkComplete || isProcessing)">
                                                            Complete
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="rm-btn rm-btn-ghost rm-btn-table"
                                                                @onclick="() => UpdateReminderStatus(reminder.Id, false)"
                                                                disabled="@isProcessing">
                                                            Incomplete
                                                        </button>
                                                    }

                                                    <button class="rm-btn rm-btn-danger rm-btn-table"
                                                            @onclick="() => DeleteReminder(reminder.Id)"
                                                            disabled="@isProcessing">
                                                        Delete
                                                    </button>
                                                </div>

                                                @if (!reminder.Completed && !canMarkComplete)
                                                {
                                                    <div class="rm-table-note">
                                                        Available after due time
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
            }
        </section>

    </div>
</div>

@code {
    private bool isProcessing;
    private string statusText = "";
    private bool isError;

    private ReminderFilter selectedFilter = ReminderFilter.All;

    private List<ReminderDto> reminders = new();
    private List<ReminderDto> filteredReminders = new();
    private List<ReminderGroupVm> groupedReminders = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var gmailStatus = await Http.GetFromJsonAsync<GoogleConnectionStatusModel>(
                "api/google-oauth/status",
                cancellationTokenSource.Token);

            if (gmailStatus?.IsConnected != true)
            {
                Navigation.NavigateTo("/google-auth");
                return;
            }

            await LoadReminders();
        }
        catch
        {
            Navigation.NavigateTo("/google-auth");
        }
    }

    private void ClearStatus()
    {
        statusText = "";
        isError = false;
    }

    private void SetStatus(string message, bool error)
    {
        statusText = message;
        isError = error;
    }

    private async Task LoadReminders()
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            reminders =
                await Http.GetFromJsonAsync<List<ReminderDto>>(
                    "api/reminder/list",
                    cancellationTokenSource.Token)
                ?? new List<ReminderDto>();

            ApplyFilterAndGrouping();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while loading reminders.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to load reminders: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ChangeFilter(ReminderFilter filter)
    {
        selectedFilter = filter;
        ApplyFilterAndGrouping();
    }

    private void ApplyFilterAndGrouping()
    {
        IEnumerable<ReminderDto> query = reminders;

        if (selectedFilter == ReminderFilter.Incomplete)
            query = query.Where(reminder => !reminder.Completed);
        else if (selectedFilter == ReminderFilter.Completed)
            query = query.Where(reminder => reminder.Completed);

        filteredReminders = query
            .OrderBy(reminder => GetGroupSortOrder(reminder))
            .ThenBy(reminder => reminder.Completed)
            .ThenBy(reminder => reminder.ReminderTime)
            .ToList();

        groupedReminders = filteredReminders
            .GroupBy(reminder => GetGroupTitle(reminder))
            .Select(group => new ReminderGroupVm
            {
                Title = group.Key,
                Items = group
                    .OrderBy(reminder => reminder.Completed)
                    .ThenBy(reminder => reminder.ReminderTime)
                    .ToList(),
                GroupOrder = group.Min(reminder => GetGroupSortOrder(reminder))
            })
            .OrderBy(group => group.GroupOrder)
            .ThenBy(group => group.Title)
            .ToList();
    }

    private string GetGroupTitle(ReminderDto reminder)
    {
        var localDate = reminder.ReminderTime.ToLocalTime().DateTime.Date;
        var today = DateTime.Now.Date;
        var tomorrow = today.AddDays(1);

        if (localDate < today)
            return "Overdue";

        if (localDate == today)
            return "Today";

        if (localDate == tomorrow)
            return "Tomorrow";

        return localDate.ToString("dddd, dd MMM yyyy");
    }

    private int GetGroupSortOrder(ReminderDto reminder)
    {
        var localDate = reminder.ReminderTime.ToLocalTime().DateTime.Date;
        var today = DateTime.Now.Date;
        var tomorrow = today.AddDays(1);

        if (localDate < today)
            return 0;

        if (localDate == today)
            return 1;

        if (localDate == tomorrow)
            return 2;

        return 100 + (localDate - today).Days;
    }

    private bool CanMarkComplete(ReminderDto reminder)
    {
        return reminder.ReminderTime <= DateTimeOffset.UtcNow;
    }

    private async Task UpdateReminderStatus(Guid reminderId, bool completed)
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.PutAsJsonAsync(
                $"api/reminder/status/{reminderId}",
                new UpdateReminderStatusRequest { Completed = completed },
                cancellationTokenSource.Token);

            var responseBody = await response.Content.ReadAsStringAsync(cancellationTokenSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Status update failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus(completed ? "Reminder marked as completed." : "Reminder marked as incomplete.", false);

            await LoadReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while updating reminder status.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to update reminder status: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteReminder(Guid reminderId)
    {
        if (isProcessing)
            return;

        try
        {
            isProcessing = true;
            ClearStatus();

            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(8));

            var response = await Http.DeleteAsync(
                $"api/reminder/delete/{reminderId}",
                cancellationTokenSource.Token);

            var responseBody = await response.Content.ReadAsStringAsync(cancellationTokenSource.Token);

            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Delete failed ({(int)response.StatusCode}): {responseBody}", true);
                return;
            }

            SetStatus("Reminder deleted.", false);

            await LoadReminders();
        }
        catch (TaskCanceledException)
        {
            SetStatus("Request timed out while deleting reminder.", true);
        }
        catch (Exception exception)
        {
            SetStatus($"Failed to delete reminder: {exception.Message}", true);
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetReminderHeading(ReminderDto reminder)
    {
        if (string.IsNullOrWhiteSpace(reminder.Title))
            return "Interview reminder";

        var title = reminder.Title.Trim();

        if (title.StartsWith("Re:", StringComparison.OrdinalIgnoreCase))
            title = title[3..].Trim();

        var atTimeIndex = title.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
        if (atTimeIndex > 0)
            title = title[..atTimeIndex].Trim();

        return string.IsNullOrWhiteSpace(title) ? "Interview reminder" : title;
    }

    private string GetCleanFromText(ReminderDto reminder)
    {
        var combinedText = ((reminder.Title ?? "") + " " + (reminder.Description ?? "")).Trim();

        var emailMatch = System.Text.RegularExpressions.Regex.Match(
            combinedText,
            @"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}");

        var emailText = emailMatch.Success ? emailMatch.Value : "";

        var nameMatch = System.Text.RegularExpressions.Regex.Match(
            combinedText,
            @"From:\s*([^<\r\n]+)",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        var nameText = nameMatch.Success ? nameMatch.Groups[1].Value.Trim() : "";

        if (string.IsNullOrWhiteSpace(nameText) && !string.IsNullOrWhiteSpace(reminder.Title))
        {
            var title = reminder.Title.Trim();

            var parenthesisStartIndex = title.LastIndexOf('(');
            var parenthesisEndIndex = title.LastIndexOf(')');

            if (parenthesisStartIndex >= 0 && parenthesisEndIndex > parenthesisStartIndex)
            {
                var possibleEmail = title[(parenthesisStartIndex + 1)..parenthesisEndIndex].Trim();
                if (possibleEmail.Contains("@", StringComparison.OrdinalIgnoreCase))
                    emailText = possibleEmail;
            }
        }

        if (!string.IsNullOrWhiteSpace(emailText))
        {
            var emailName = emailText.Split('@')[0]
                .Replace(".", " ")
                .Replace("_", " ")
                .Trim();

            var readableEmailName = ToTitleCaseSafe(emailName);

            if (!string.IsNullOrWhiteSpace(nameText))
                return $"{nameText} ({emailText})";

            return $"{readableEmailName} ({emailText})";
        }

        if (!string.IsNullOrWhiteSpace(nameText))
            return nameText;

        return "Not available";
    }

    private string GetCleanWhereText(ReminderDto reminder)
    {
        if (string.IsNullOrWhiteSpace(reminder.Title))
            return "Not available";

        var title = reminder.Title.Trim();

        var fromIndex = title.IndexOf(" from ", StringComparison.OrdinalIgnoreCase);
        if (fromIndex >= 0)
        {
            var companyText = title[(fromIndex + 6)..].Trim();

            var atTimeIndex = companyText.IndexOf(" @ ", StringComparison.OrdinalIgnoreCase);
            if (atTimeIndex > 0)
                companyText = companyText[..atTimeIndex].Trim();

            var onIndex = companyText.IndexOf(" on ", StringComparison.OrdinalIgnoreCase);
            if (onIndex > 0)
                companyText = companyText[..onIndex].Trim();

            if (!string.IsNullOrWhiteSpace(companyText))
                return companyText;
        }

        if (title.Contains("Interview Alert", StringComparison.OrdinalIgnoreCase))
            return "Interview Alert";

        return "Not available";
    }

    private string ToTitleCaseSafe(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "";

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(word => char.ToUpperInvariant(word[0]) + word[1..].ToLowerInvariant());

        return string.Join(" ", words);
    }

    private string BuildHistoryDescription(ReminderDto reminder)
    {
        var sender = GetCleanFromText(reminder);
        var company = GetCleanWhereText(reminder);
        var purpose = GetPurposeText(reminder);

        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(sender) && !sender.Equals("Not available", StringComparison.OrdinalIgnoreCase))
            parts.Add(sender);

        if (!string.IsNullOrWhiteSpace(company) && !company.Equals("Not available", StringComparison.OrdinalIgnoreCase))
            parts.Add(company);

        if (!string.IsNullOrWhiteSpace(purpose))
            parts.Add(purpose);

        if (parts.Count == 0)
            return string.IsNullOrWhiteSpace(reminder.Description) ? "-" : reminder.Description!;

        return string.Join(" | ", parts);
    }

    private string GetPurposeText(ReminderDto reminder)
    {
        var combinedText = ((reminder.Title ?? "") + " " + (reminder.Description ?? "")).Trim();

        if (string.IsNullOrWhiteSpace(combinedText))
            return "General Reminder";

        if (combinedText.Contains("interview", StringComparison.OrdinalIgnoreCase))
            return "Interview";

        if (combinedText.Contains("meeting", StringComparison.OrdinalIgnoreCase))
            return "Meeting";

        if (combinedText.Contains("call", StringComparison.OrdinalIgnoreCase))
            return "Call";

        if (combinedText.Contains("appointment", StringComparison.OrdinalIgnoreCase))
            return "Appointment";

        if (combinedText.Contains("invoice", StringComparison.OrdinalIgnoreCase))
            return "Invoice";

        if (combinedText.Contains("follow up", StringComparison.OrdinalIgnoreCase))
            return "Follow Up";

        return "General Reminder";
    }
    public sealed class ReminderDto
    {
        public Guid Id { get; set; }
        public string? Title { get; set; }
        public string? Description { get; set; }
        public DateTimeOffset ReminderTime { get; set; }
        public string ReminderTimeLocalText { get; set; } = "";
        public bool Completed { get; set; }
        public DateTime CreatedOn { get; set; }
    }

    public sealed class GoogleConnectionStatusModel
    {
        public bool IsConnected { get; set; }
        public bool NeedsReconnect { get; set; }
        public string Provider { get; set; } = "Gmail";
        public string Email { get; set; } = "";
        public string Message { get; set; } = "";
    }

    public sealed class UpdateReminderStatusRequest
    {
        public bool Completed { get; set; }
    }

    public sealed class ReminderGroupVm
    {
        public string Title { get; set; } = "";
        public int GroupOrder { get; set; }
        public List<ReminderDto> Items { get; set; } = new();
    }

    public enum ReminderFilter
    {
        All = 1,
        Incomplete = 2,
        Completed = 3
    }
}

